# ============================================================
# .env.example — Plantilla de variables de entorno
# Copia este archivo como .env y rellena los valores reales.
# NUNCA subir el .env real a git.
# ============================================================

# ------------------------------------------------------------
# APP
# El código vive en la RAÍZ del dominio/subdominio (no en /cotizador):
#   Principal:  APP_URL=https://elgringo.pe        APP_PATH=/home/ebakxdhm/elgringo.pe
#   Otra ciudad: APP_URL=https://marcona.elgringo.pe  APP_PATH=/home/ebakxdhm/marcona.elgringo.pe
# Cada ciudad = su propio .env (APP_URL, APP_PATH, DB y UPLOAD propios). Mismo código.
# ------------------------------------------------------------
APP_URL=https://elgringo.pe
APP_PATH=/home/ebakxdhm/elgringo.pe

# ------------------------------------------------------------
# BASE DE DATOS
# ------------------------------------------------------------
DB_HOST=localhost
DB_NAME=ebakxdhm_cotizador
DB_USER=
DB_PASS=

# ------------------------------------------------------------
# UPLOADS
# ------------------------------------------------------------
UPLOAD_URL=https://elgringo.pe/assets/img/uploads/
UPLOAD_PATH=/home/ebakxdhm/elgringo.pe/assets/img/uploads/
MAX_FILE_SIZE=2097152

# ------------------------------------------------------------
# EMAIL
# ------------------------------------------------------------
MAIL_FROM=
MAIL_FROM_NAME=
MAIL_REPLY_TO=

# ------------------------------------------------------------
# SESIÓN
# ------------------------------------------------------------
SESSION_NAME=elgringo_session

# ------------------------------------------------------------
# IZIPAY (Micuentaweb / Lyra) — pago con tarjeta en la carta de venta
# Saca estos valores del Back Office de Izipay:
#   Configuración → Tienda → Claves de API REST
# Empieza SIEMPRE en TEST. Cuando todo funcione, cambia a PRODUCTION
# y rellena las claves _PROD.
# ------------------------------------------------------------
IZIPAY_MODE=TEST
IZIPAY_SHOP_ID=
IZIPAY_REST_SERVER=https://api.micuentaweb.pe
IZIPAY_JS_URL=https://static.micuentaweb.pe/static/js/krypton-client/V4.0/stable/kr-payment-form.min.js

# TEST
IZIPAY_PUBLIC_KEY_TEST=
IZIPAY_REST_PASS_TEST=
IZIPAY_HMAC_TEST=

# PRODUCTION
IZIPAY_PUBLIC_KEY_PROD=
IZIPAY_REST_PASS_PROD=
IZIPAY_HMAC_PROD=
