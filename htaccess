Options -Indexes
ServerSignature Off

# Proteger archivos sensibles
<FilesMatch "\.(sql|log|env|json|lock)$">
    Order allow,deny
    Deny from all
</FilesMatch>

<IfModule mod_rewrite.c>
    RewriteEngine On

    # URLs SIN .php
    RewriteCond %{REQUEST_FILENAME} !-f
    RewriteCond %{REQUEST_FILENAME} !-d
    RewriteCond %{REQUEST_FILENAME}.php -f
    RewriteRule ^(.*)$ $1.php [L,QSA]

    # URL amigable: /solicitud -> solicitud.php
    RewriteRule ^solicitud/?$ solicitud.php [L,QSA]

    # Bloquear carpetas internas
    RewriteRule ^config/  - [F,L]
    RewriteRule ^includes/ - [F,L]
    RewriteRule ^vendor/   - [F,L]

    # Carta por slug — cuando el cotizador ES el docroot del dominio
    # (instancia servida en su propia raíz, ej. marcona.elgringo.pe/{tienda}).
    # En Lima estas URLs las maneja el .htaccess de /elgringo, no estas reglas.
    RewriteCond %{REQUEST_FILENAME} !-f
    RewriteCond %{REQUEST_FILENAME} !-d
    RewriteRule ^([a-zA-Z0-9_-]+)/menu/?$ carta/menu.php?slug=$1 [L,QSA]

    RewriteCond %{REQUEST_FILENAME} !-f
    RewriteCond %{REQUEST_FILENAME} !-d
    RewriteRule ^([a-zA-Z0-9_-]+)/?$ carta/index.php?slug=$1 [L,QSA]
</IfModule>

# Headers de seguridad + no-cache para PHP
<IfModule mod_headers.c>
    Header always set X-Content-Type-Options "nosniff"
    Header always set X-Frame-Options "SAMEORIGIN"
    Header always set X-XSS-Protection "1; mode=block"
    Header always set Referrer-Policy "strict-origin-when-cross-origin"

    # No cachear paginas PHP
    <FilesMatch "\.php$">
        Header set Cache-Control "no-store, no-cache, must-revalidate, max-age=0"
        Header set Pragma "no-cache"
        Header set Expires "0"
    </FilesMatch>
</IfModule>

# Compresion
<IfModule mod_deflate.c>
    AddOutputFilterByType DEFLATE text/html text/css application/javascript
</IfModule>

# Cache de assets estaticos
<IfModule mod_expires.c>
    ExpiresActive On
    ExpiresByType image/jpeg "access plus 1 month"
    ExpiresByType image/png  "access plus 1 month"
    ExpiresByType image/webp "access plus 1 month"
    ExpiresByType text/css   "access plus 1 week"
    ExpiresByType application/javascript "access plus 1 week"
</IfModule>
